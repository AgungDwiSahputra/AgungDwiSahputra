---
import { getCollection } from 'astro:content';
import ProjectCard from '../ui/ProjectCard.astro';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year);
---

<section id="projects" class="py-24 lg:py-32 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <div class="h-px bg-gradient-to-r from-transparent via-white/10 to-transparent mb-24" aria-hidden="true"></div>

    <!-- Section header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12" data-animate>
      <div>
        <p class="section-label" data-i18n="projects.label">Portfolio</p>
        <h2 class="text-3xl lg:text-4xl font-bold text-white" data-i18n="projects.title">Proyek Unggulan</h2>
        <p class="text-white/45 mt-2 text-sm" data-i18n="projects.subtitle">Beberapa proyek terpilih yang menunjukkan keahlian teknis saya.</p>
      </div>
      <a
        href={`${import.meta.env.BASE_URL}projects`}
        class="shrink-0 flex items-center gap-2 text-sm text-blue-400 hover:text-blue-300 transition-colors font-medium"
      >
        <span data-i18n="projects.viewall">Lihat semua proyek</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>

    <!-- Project grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {featured.map((project, i) => (
        <div data-animate data-delay={String(i * 100)}>
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            category={project.data.category}
            tags={project.data.tags}
            year={project.data.year}
            slug={project.id}
            thumbnail={project.data.thumbnail}
            liveUrl={project.data.liveUrl}
            repoUrl={project.data.repoUrl}
            featured={project.data.featured}
          />
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center mt-12" data-animate>
      <a href={`${import.meta.env.BASE_URL}projects`} class="btn-outline">
        Lihat Semua Proyek
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
