---
import profileData from '../../content/profile.json';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section id="home" class="min-h-screen flex items-center pt-16 relative overflow-hidden">

  <!-- Background blobs -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-1/4 left-1/3 w-[500px] h-[500px] rounded-full bg-blue-600/8 blur-3xl animate-blob"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full bg-purple-600/8 blur-3xl animate-blob-delay"></div>
    <div class="absolute top-3/4 left-1/4 w-64 h-64 rounded-full bg-cyan-600/5 blur-3xl"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

      <!-- ─── Left: Text ──────────────────────── -->
      <div>
        <!-- Available badge -->
        <div class="inline-flex items-center gap-2 glass px-4 py-2 rounded-full text-xs text-green-400 font-medium mb-8 border-green-500/20">
          <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse" aria-hidden="true"></span>
          <span data-i18n="hero.available">Terbuka untuk peluang karir</span>
        </div>

        <h1 class="font-bold leading-tight mb-4">
          <span class="block text-white/50 text-xl font-normal mb-1" data-i18n="hero.greeting">Hai, saya</span>
          <span class="block text-5xl lg:text-6xl gradient-text">Agung Dwi</span>
          <span class="block text-5xl lg:text-6xl gradient-text">Sahputra</span>
        </h1>

        <p class="text-xl text-blue-300 font-semibold mb-4" data-i18n="hero.role">
          Full-Stack Web Developer
        </p>

        <p class="text-white/55 text-base leading-relaxed mb-8 max-w-lg" data-i18n="hero.bio">
          3+ tahun membangun aplikasi web yang responsif, scalable, dan SEO-friendly.
          Spesialis Laravel, TailwindCSS, dan sistem GIS berbasis peta.
        </p>

        <!-- Stats -->
        <div class="flex items-center gap-6 mb-10" aria-label="Statistik karir">
          <div class="text-center">
            <p class="text-2xl font-bold gradient-text">3+</p>
            <p class="text-white/40 text-xs mt-0.5" data-i18n="hero.years_label">Tahun Exp.</p>
          </div>
          <div class="w-px h-8 bg-white/10" aria-hidden="true"></div>
          <div class="text-center">
            <p class="text-2xl font-bold gradient-text">98%</p>
            <p class="text-white/40 text-xs mt-0.5" data-i18n="hero.sat_label">Client Puas</p>
          </div>
          <div class="w-px h-8 bg-white/10" aria-hidden="true"></div>
          <div class="text-center">
            <p class="text-2xl font-bold gradient-text">100%</p>
            <p class="text-white/40 text-xs mt-0.5" data-i18n="hero.time_label">Tepat Waktu</p>
          </div>
        </div>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap items-center gap-3 mb-8">
          <a href="#projects" class="btn-primary">
            <span data-i18n="hero.cta_projects">Lihat Proyek</span>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href={`${base}${profileData.cv}`} download class="btn-outline">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            <span data-i18n="hero.cta_cv">Unduh CV</span>
          </a>
        </div>

        <!-- Social Links -->
        <div class="flex items-center gap-5">
          <a href={profileData.social.linkedin} target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 text-white/40 hover:text-blue-400 transition-colors text-sm"
            aria-label="LinkedIn Agung Dwi Sahputra">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            LinkedIn
          </a>
          <span class="text-white/15" aria-hidden="true">·</span>
          <a href={profileData.social.github} target="_blank" rel="noopener noreferrer"
            class="flex items-center gap-2 text-white/40 hover:text-blue-400 transition-colors text-sm"
            aria-label="GitHub Agung Dwi Sahputra">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
            GitHub
          </a>
          <span class="text-white/15" aria-hidden="true">·</span>
          <a href={profileData.social.email}
            class="flex items-center gap-2 text-white/40 hover:text-blue-400 transition-colors text-sm"
            aria-label="Email Agung Dwi Sahputra">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Email
          </a>
        </div>
      </div>

      <!-- ─── Right: Photo ─────────────────────── -->
      <div class="flex justify-center lg:justify-end" aria-hidden="true">
        <div class="relative">
          <div class="absolute inset-0 bg-blue-500/15 rounded-full blur-3xl scale-125 pointer-events-none"></div>
          <div class="absolute inset-0 bg-purple-500/10 rounded-full blur-2xl scale-110 pointer-events-none"></div>
          <div class="relative p-[3px] rounded-full" style="background: linear-gradient(135deg, rgba(59,130,246,0.6), rgba(139,92,246,0.6));">
            <div class="p-[3px] rounded-full glass">
              <img
                src={`${base}/images/profile.jpg`}
                alt="Foto profil Agung Dwi Sahputra"
                width="320"
                height="320"
                class="w-72 h-72 lg:w-80 lg:h-80 rounded-full object-cover object-top"
                loading="eager"
              />
            </div>
          </div>
          <!-- Floating tech tags -->
          <div class="absolute -top-2 -right-4 glass px-3 py-1.5 rounded-full text-xs text-blue-300 font-medium shadow-lg">Laravel</div>
          <div class="absolute top-1/2 -right-12 glass px-3 py-1.5 rounded-full text-xs text-cyan-300 font-medium shadow-lg" style="transform:translateY(-50%)">ASP.Net</div>
          <div class="absolute bottom-10 -left-10 glass px-3 py-1.5 rounded-full text-xs text-purple-300 font-medium shadow-lg">TailwindCSS</div>
          <div class="absolute top-8 -left-6 glass px-3 py-1.5 rounded-full text-xs text-green-300 font-medium shadow-lg">ReactJS</div>
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 opacity-30" aria-hidden="true">
    <span class="text-white text-xs tracking-widest">SCROLL</span>
    <svg class="w-4 h-4 text-white animate-bounce" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
    </svg>
  </div>
</section>
