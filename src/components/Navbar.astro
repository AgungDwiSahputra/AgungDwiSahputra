---
import SearchModal from './SearchModal.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navItems = [
  { label: 'Tentang',  key: 'nav.about',    href: '#about'    },
  { label: 'Keahlian', key: 'nav.skills',   href: '#skills'   },
  { label: 'Proyek',   key: 'nav.projects', href: '#projects' },
  { label: 'Kontak',   key: 'nav.contact',  href: '#contact'  },
];
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-300" id="navbar" data-pagefind-ignore>
  <nav class="glass border-b border-white/5 px-4 sm:px-6 lg:px-8" aria-label="Navigasi utama">
    <div class="max-w-6xl mx-auto flex items-center justify-between h-16">

      <!-- Brand -->
      <a href={base || '/'} class="text-white font-bold text-lg tracking-tight hover:text-blue-400 transition-colors" aria-label="Agung Dwi Sahputra - Beranda">
        <span class="gradient-text">Agung</span><span class="text-white/50 font-normal">.dev</span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden md:flex items-center gap-0.5" role="list">
        {navItems.map(item => (
          <li>
            <a href={item.href} class="px-3.5 py-2 rounded-lg text-sm text-white/65 hover:text-white hover:bg-white/5 transition-all duration-200" data-i18n={item.key}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop: Search + Lang + CV -->
      <div class="hidden md:flex items-center gap-2">
        <!-- Search trigger -->
        <SearchModal />

        <!-- Language toggle -->
        <button
          id="lang-toggle"
          onclick="window.toggleLang?.()"
          class="px-2.5 py-1.5 rounded-lg text-xs font-semibold text-white/50 hover:text-white border border-white/10 hover:border-white/20 hover:bg-white/5 transition-all tracking-wider"
          aria-label="Toggle bahasa / Toggle language"
          title="Switch language"
        >
          EN
        </button>

        <!-- CV button -->
        <a
          href={`${base}/cv/agung-cv.pdf`}
          download
          class="px-3.5 py-2 rounded-lg text-sm font-medium bg-blue-500/15 text-blue-300 border border-blue-500/25 hover:bg-blue-500/25 hover:border-blue-400/40 transition-all duration-200"
          data-i18n="nav.downloadcv"
        >
          Unduh CV
        </a>
      </div>

      <!-- Mobile: right side controls -->
      <div class="md:hidden flex items-center gap-2">
        <!-- Mobile search trigger -->
        <button
          id="mobile-search-trigger"
          class="p-2 rounded-lg text-white/50 hover:text-white hover:bg-white/5 transition-all"
          aria-label="Cari konten"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
          </svg>
        </button>

        <!-- Hamburger -->
        <button
          id="menu-toggle"
          class="p-2 rounded-lg text-white/65 hover:text-white hover:bg-white/5 transition-all"
          aria-label="Buka menu navigasi"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg id="icon-open"  class="w-5 h-5"        fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="md:hidden hidden border-t border-white/8 py-3" role="menu" aria-label="Menu mobile">
      {navItems.map(item => (
        <a href={item.href} class="block px-4 py-3 text-sm text-white/65 hover:text-white hover:bg-white/5 rounded-lg transition-all" role="menuitem" data-i18n={item.key}>
          {item.label}
        </a>
      ))}
      <div class="flex items-center gap-2 px-4 pt-3 pb-1 border-t border-white/8 mt-2">
        <a href={`${base}/cv/agung-cv.pdf`} download class="flex-1 text-center py-2.5 text-sm font-medium rounded-lg bg-blue-500/15 text-blue-300 border border-blue-500/25" data-i18n="nav.downloadcv" role="menuitem">
          Unduh CV
        </a>
        <button
          onclick="window.toggleLang?.()"
          class="px-3 py-2.5 rounded-lg text-xs font-semibold text-white/50 border border-white/10 hover:border-white/20 hover:bg-white/5 transition-all tracking-wider"
          aria-label="Toggle bahasa"
        >
          EN
        </button>
      </div>
    </div>
  </nav>
</header>

<script>
  // ── Mobile hamburger ─────────────────────────────
  const toggle   = document.getElementById('menu-toggle');
  const menu     = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('icon-open');
  const iconClose = document.getElementById('icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden', isOpen);
    iconOpen?.classList.toggle('hidden', !isOpen);
    iconClose?.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });

  // ── Scroll shadow ────────────────────────────────
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('shadow-lg', window.scrollY > 20);
  }, { passive: true });

  // ── Mobile search opens the same modal ───────────
  document.getElementById('mobile-search-trigger')?.addEventListener('click', () => {
    document.getElementById('search-trigger')?.click();
  });

  // ── Sync lang toggle button across desktop/mobile ─
  // The mobile toggle button text is handled by applyLang in BaseLayout
  // but mobile toggle buttons have no id, so we find all lang-toggle-like buttons
  const allLangToggles = document.querySelectorAll<HTMLButtonElement>('[onclick="window.toggleLang?.()"]');
  const currentLang = localStorage.getItem('portfolio-lang') ?? 'id';
  allLangToggles.forEach(btn => {
    btn.textContent = currentLang === 'id' ? 'EN' : 'ID';
  });
</script>
