---
interface Props {
  title: string;
  description: string;
  category: string;
  tags: string[];
  year: number;
  slug: string;
  thumbnail?: string;
  liveUrl?: string;
  repoUrl?: string;
  featured?: boolean;
}

const {
  title, description, category, tags, year,
  slug, thumbnail, liveUrl, repoUrl, featured = false,
} = Astro.props;

const categoryColors: Record<string, string> = {
  'GIS':     'bg-cyan-500/15 text-cyan-300 border-cyan-500/25',
  'Web Dev': 'bg-blue-500/15 text-blue-300 border-blue-500/25',
  'Mobile':  'bg-purple-500/15 text-purple-300 border-purple-500/25',
  'Data':    'bg-amber-500/15 text-amber-300 border-amber-500/25',
};

const categoryGradients: Record<string, string> = {
  'GIS':     'from-cyan-600/30 to-blue-700/30',
  'Web Dev': 'from-blue-600/30 to-indigo-700/30',
  'Mobile':  'from-purple-600/30 to-pink-700/30',
  'Data':    'from-amber-600/30 to-orange-700/30',
};

const badgeClass = categoryColors[category] ?? 'bg-white/10 text-white/60 border-white/15';
const gradientClass = categoryGradients[category] ?? 'from-slate-600/30 to-slate-800/30';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<article class={`glass glass-hover rounded-2xl overflow-hidden flex flex-col h-full transition-transform duration-300 hover:-translate-y-1 ${featured ? 'border-blue-500/20' : ''}`}>

  <!-- Thumbnail -->
  <div class={`relative h-44 bg-gradient-to-br ${gradientClass} overflow-hidden`}>
    {thumbnail ? (
      <img
        src={thumbnail}
        alt={`Screenshot proyek ${title}`}
        class="w-full h-full object-cover opacity-80"
        loading="lazy"
      />
    ) : (
      <!-- Placeholder gradient -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-5xl font-black text-white/8 select-none">{title.charAt(0)}</div>
      </div>
    )}
    <!-- Category badge -->
    <span class={`absolute top-3 right-3 text-xs px-2.5 py-1 rounded-full font-medium border ${badgeClass}`}>
      {category}
    </span>
    {featured && (
      <span class="absolute top-3 left-3 text-xs px-2.5 py-1 rounded-full font-medium bg-yellow-500/15 text-yellow-300 border border-yellow-500/25">
        Featured
      </span>
    )}
  </div>

  <!-- Content -->
  <div class="p-5 flex flex-col flex-1">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="text-white font-semibold text-base leading-snug">{title}</h3>
      <span class="text-white/25 text-xs shrink-0">{year}</span>
    </div>

    <p class="text-white/50 text-sm leading-relaxed mb-4 flex-1 line-clamp-3">
      {description}
    </p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {tags.slice(0, 4).map(tag => (
        <span class="tag">{tag}</span>
      ))}
      {tags.length > 4 && (
        <span class="tag">+{tags.length - 4}</span>
      )}
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-2 mt-auto pt-1 border-t border-white/5">
      <a
        href={`${base}/projects/${slug}`}
        class="flex-1 text-center py-2 rounded-lg text-xs font-medium text-blue-300 bg-blue-500/10 border border-blue-500/20 hover:bg-blue-500/20 hover:border-blue-400/30 transition-all"
      >
        Lihat Detail →
      </a>
      {liveUrl && (
        <a
          href={liveUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 rounded-lg text-white/40 hover:text-white bg-white/5 border border-white/10 hover:bg-white/10 transition-all"
          aria-label={`Live demo ${title}`}
          title="Live Demo"
        >
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
        </a>
      )}
      {repoUrl && (
        <a
          href={repoUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="p-2 rounded-lg text-white/40 hover:text-white bg-white/5 border border-white/10 hover:bg-white/10 transition-all"
          aria-label={`Source code ${title}`}
          title="Source Code"
        >
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
      )}
    </div>
  </div>
</article>
