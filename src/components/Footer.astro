---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/10 mt-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-white/40 text-sm">
        &copy; {year} <span class="text-white/60">Agung Dwi Sahputra</span>. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a
          href="https://www.linkedin.com/in/agung-ds20"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/40 hover:text-blue-400 transition-colors text-sm"
          aria-label="LinkedIn Agung"
        >
          LinkedIn
        </a>
        <span class="text-white/20" aria-hidden="true">·</span>
        <a
          href="https://github.com/AgungDwiSahputra"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/40 hover:text-blue-400 transition-colors text-sm"
          aria-label="GitHub Agung"
        >
          GitHub
        </a>
        <span class="text-white/20" aria-hidden="true">·</span>
        <a
          href="mailto:agungdwisahputra@gmail.com"
          class="text-white/40 hover:text-blue-400 transition-colors text-sm"
          aria-label="Email Agung"
        >
          Email
        </a>
      </div>
    </div>
  </div>
</footer>
