---
// SearchModal — powered by Pagefind (available after `npm run build`)
---

<!-- Search trigger (used by Navbar) -->
<button
  id="search-trigger"
  class="flex items-center gap-2 px-3 py-1.5 rounded-lg text-white/50 hover:text-white text-sm
         bg-white/0 hover:bg-white/5 border border-transparent hover:border-white/10 transition-all duration-200"
  aria-label="Cari konten (Ctrl+K)"
  title="Cari (Ctrl+K)"
>
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
  </svg>
  <span class="hidden sm:inline text-xs" data-i18n="nav.search">Cari</span>
  <kbd class="hidden lg:inline text-[10px] px-1.5 py-0.5 rounded bg-white/8 border border-white/10 text-white/30 font-mono">⌘K</kbd>
</button>

<!-- Modal overlay -->
<div
  id="search-modal"
  role="dialog"
  aria-label="Pencarian situs"
  aria-modal="true"
  class="hidden fixed inset-0 z-[200] flex items-start justify-center pt-16 sm:pt-24 px-4"
  data-pagefind-ignore
>
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Modal panel -->
  <div class="relative w-full max-w-2xl">
    <div class="glass border-white/15 rounded-2xl shadow-2xl overflow-hidden">

      <!-- Search input -->
      <div class="flex items-center gap-3 px-4 py-3 border-b border-white/8">
        <svg class="w-5 h-5 text-white/40 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
        </svg>
        <input
          id="search-input"
          type="search"
          placeholder="Cari proyek, keahlian, pengalaman..."
          class="flex-1 bg-transparent text-white placeholder-white/30 text-sm outline-none"
          autocomplete="off"
          spellcheck="false"
          aria-label="Input pencarian"
        />
        <button id="search-close" class="text-white/30 hover:text-white/70 transition-colors" aria-label="Tutup pencarian">
          <kbd class="text-xs px-1.5 py-0.5 rounded border border-white/15 text-white/30">Esc</kbd>
        </button>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-80 overflow-y-auto divide-y divide-white/5" role="listbox" aria-label="Hasil pencarian">
        <!-- Populated by JS -->
      </div>

      <!-- Footer hint -->
      <div class="px-4 py-2.5 border-t border-white/8 flex items-center gap-4 text-white/25 text-xs">
        <span class="flex items-center gap-1">
          <kbd class="px-1 py-0.5 rounded border border-white/15 font-mono text-[10px]">↑↓</kbd>
          navigasi
        </span>
        <span class="flex items-center gap-1">
          <kbd class="px-1 py-0.5 rounded border border-white/15 font-mono text-[10px]">↵</kbd>
          buka
        </span>
        <span class="flex items-center gap-1">
          <kbd class="px-1 py-0.5 rounded border border-white/15 font-mono text-[10px]">Esc</kbd>
          tutup
        </span>
        <span class="ml-auto">Powered by Pagefind</span>
      </div>

    </div>
  </div>
</div>

<script>
  const modal     = document.getElementById('search-modal')!;
  const backdrop  = document.getElementById('search-backdrop')!;
  const input     = document.getElementById('search-input') as HTMLInputElement;
  const results   = document.getElementById('search-results')!;
  const trigger   = document.getElementById('search-trigger')!;
  const closeBtn  = document.getElementById('search-close')!;

  let pagefind: any = null;
  let activeIndex = -1;

  // ── Open / Close ────────────────────────────────
  function openModal() {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    setTimeout(() => input.focus(), 50);
    loadPagefind();
  }

  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    input.value = '';
    results.innerHTML = '';
    activeIndex = -1;
    trigger.focus();
  }

  trigger.addEventListener('click', openModal);
  backdrop.addEventListener('click', closeModal);
  closeBtn.addEventListener('click', closeModal);

  // Focus trap — keep Tab/Shift+Tab inside modal
  modal.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab' || modal.classList.contains('hidden')) return;
    const focusable = Array.from(
      modal.querySelectorAll<HTMLElement>('button, input, a[href], [tabindex]:not([tabindex="-1"])')
    ).filter(el => !el.hasAttribute('disabled'));
    if (!focusable.length) return;
    const first = focusable[0];
    const last  = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });

  // Ctrl/Cmd+K shortcut
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      modal.classList.contains('hidden') ? openModal() : closeModal();
    }
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) closeModal();
  });

  // ── Load Pagefind (lazy) ─────────────────────────
  const DEV_HINT = `
    <div class="px-5 py-8 text-center text-white/30 text-sm">
      <p class="mb-1.5 text-white/40 font-medium">Search aktif setelah build</p>
      <p class="mb-1">Jalankan <code class="text-blue-400 text-xs px-1 py-0.5 rounded bg-blue-500/10">npm run build</code> untuk mengindeks konten.</p>
      <p class="text-xs text-white/20 mt-2">Pagefind mengindeks semua halaman saat proses build.</p>
    </div>`;

  async function loadPagefind() {
    if (pagefind) return;
    try {
      const pagefindUrl = import.meta.env.BASE_URL + 'pagefind/pagefind.js';
      const pf = await import(/* @vite-ignore */ pagefindUrl);
      // Stub diinjeksi oleh vite plugin di dev mode — tandai dengan __isDev
      if ((pf as any).__isDev) {
        results.innerHTML = DEV_HINT;
        return;
      }
      await pf.init();
      pagefind = pf;
    } catch {
      results.innerHTML = DEV_HINT;
    }
  }

  // ── Search ───────────────────────────────────────
  let debounceTimer: ReturnType<typeof setTimeout>;

  input.addEventListener('input', () => {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => doSearch(input.value.trim()), 250);
  });

  async function doSearch(query: string) {
    if (!pagefind) { if (query) results.innerHTML = DEV_HINT; return; }
    if (!query) { results.innerHTML = ''; return; }

    const search = await pagefind.search(query);
    const hits = await Promise.all(search.results.slice(0, 6).map((r: any) => r.data()));

    if (hits.length === 0) {
      results.innerHTML = `<div class="px-5 py-8 text-center text-white/30 text-sm">Tidak ada hasil untuk "<strong class="text-white/50">${escHtml(query)}</strong>"</div>`;
      return;
    }

    activeIndex = -1;
    results.innerHTML = hits.map((hit: any, i: number) => `
      <a
        href="${hit.url}"
        role="option"
        data-result-index="${i}"
        class="result-item flex flex-col px-5 py-4 hover:bg-white/5 transition-colors cursor-pointer"
        aria-selected="false"
      >
        <span class="text-white/80 text-sm font-medium truncate">${hit.meta?.title ?? 'Halaman'}</span>
        <span class="text-white/40 text-xs leading-relaxed mt-0.5 line-clamp-2">${hit.excerpt ?? ''}</span>
      </a>
    `).join('');

    // Link click closes modal
    results.querySelectorAll('.result-item').forEach(el => {
      el.addEventListener('click', closeModal);
    });
  }

  // ── Keyboard navigation ──────────────────────────
  input.addEventListener('keydown', (e) => {
    const items = results.querySelectorAll<HTMLElement>('.result-item');
    if (!items.length) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(items, Math.min(activeIndex + 1, items.length - 1));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(items, Math.max(activeIndex - 1, 0));
    } else if (e.key === 'Enter' && activeIndex >= 0) {
      items[activeIndex]?.click();
    }
  });

  function setActive(items: NodeListOf<HTMLElement>, idx: number) {
    items[activeIndex]?.setAttribute('aria-selected', 'false');
    items[activeIndex]?.classList.remove('bg-white/5');
    activeIndex = idx;
    items[activeIndex]?.setAttribute('aria-selected', 'true');
    items[activeIndex]?.classList.add('bg-white/5');
    items[activeIndex]?.scrollIntoView({ block: 'nearest' });
  }

  function escHtml(s: string) {
    return s.replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' })[c]!);
  }
</script>
